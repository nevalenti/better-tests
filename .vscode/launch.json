{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to .NET API",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}",
      "justMyCode": true
    },
    {
      "name": "Chrome - Angular Web",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "urlFilter": "http://localhost:4200/*",
      "pathMapping": {
        "/": "${workspaceRoot}/apps/web/",
        "/src": "${workspaceRoot}/apps/web/src"
      }
    },
    {
      "name": "Launch API & Web (Compound)",
      "type": "node",
      "request": "launch",
      "preLaunchTask": "start-api",
      "postDebugTask": "stop-services"
    }
  ],
  "compounds": [
    {
      "name": "Debug API + Web",
      "configurations": ["Attach to .NET API", "Chrome - Angular Web"],
      "stopAll": true
    }
  ]
}
